  "name": "Security & Compliance Agent",
  "nodes": [
    {
      "parameters": {
        "content": "## Security & Compliance Agent\nSub-agent called by The Brain for all security and compliance operations.\n\n**Assign your Chat Model to the AI Agent node.**\nAfter importing all sub-workflows, replace the placeholder IDs below.\n\nThis agent handles:\n- Querying malware detection events\n- Querying authorization and audit events\n- Scanning backups for malware\n- Retrieving scan results",
        "height": 220,
        "width": 520,
        "color": 3
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        0,
        0
      ],
      "id": "aa000001-0000-0000-0000-000000000001",
      "name": "Setup Note"
    },
    {
      "parameters": {
        "workflowInputs": {
          "values": [
            {
              "name": "query"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        304
      ],
      "id": "aa000002-0000-0000-0000-000000000002",
      "name": "Execute Workflow Trigger"
    },
