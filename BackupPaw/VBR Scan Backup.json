      ],
      "id": "f6a7b8c9-d0e1-2345-fabc-456789012345",
      "name": "Get Restore Points"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json.data;\nconst vmName = $('Start').item.json.vmName;\n\nif (!data || data.length === 0) {\n  throw new Error('No restore points found for VM: ' + vmName);\n}\n\n// Filter to VMware platform only, take the most recent (already sorted desc)\nconst vmPoints = data.filter(p => p.platformName === 'VMware' || p.name.toLowerCase().includes(vmName.toLowerCase()));\nconst latest = vmPoints.length > 0 ? vmPoints[0] : data[0];\n\nreturn [{ json: { backupId: latest.backupId, creationTime: latest.creationTime, vmName: latest.name } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        288,
        0
      ],
      "id": "a7b8c9d0-e1f2-3456-abcd-567890123456",
      "name": "Extract Restore Point"
    },
    {
      "parameters": {
        "url": "={{ $('Get Bearer Token').item.json.url }}/api/v1/backups/{{ $json.backupId }}/objects",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-version",
              "value": "={{ $('Get Bearer Token').item.json.apiVersion }}"
            },
            {
              "name": "=Authorization",
              "value": "=Bearer {{ $('Get Bearer Token').item.json.access_token }}"
            }
          ]
        },
        "options": {
          "allowUnauthorizedCerts": true
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        512,
        0
      ],
      "id": "b8c9d0e1-f2a3-4567-bcde-678901234567",
      "name": "Get Backup Objects"
    },
    {
      "parameters": {
        "jsCode": "const objects = $input.first().json.data;\nconst vmName = $('Start').item.json.vmName;\nconst daysBack = parseInt($('Start').item.json.daysBack) || 7;\nconst backupId = $('Extract Restore Point').item.json.backupId;\n\nif (!objects || objects.length === 0) {\n  throw new Error('No backup objects found in backup: ' + backupId);\n}\n\n// Find object matching vmName (case-insensitive), fall back to first\nconst obj = objects.find(o => o.name.toLowerCase() === vmName.toLowerCase()) || objects[0];\n\nconst now = new Date();\nconst endDate = new Date(now);\nendDate.setDate(endDate.getDate() - daysBack);\n\nreturn [{\n  json: {\n    backupObjectPair: [{ backupId: backupId, backupObjectId: obj.id }],\n    scanMode: \"MostRecent\",\n    scanEngine: { useAntivirusEngine: true, useYaraRule: false },\n    scanRange: {\n      from: { useMostRecentPoint: true },\n      to: { useOldestPoint: false, endDate: endDate.toISOString() }\n    },\n    _meta: { vmName: obj.name, backupId: backupId, backupObjectId: obj.id, scanUntil: endDate.toISOString() }\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        736,
        0
      ],
      "id": "c9d0e1f2-a3b4-5678-cdef-789012345678",
      "name": "Build Scan Body"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Get Bearer Token').item.json.url }}/api/v1/malwareDetection/scanBackup",
        "sendHeaders": true,
        "headerParameters": {
