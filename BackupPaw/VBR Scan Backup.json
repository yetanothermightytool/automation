        "jsonBody": "={{ JSON.stringify({ backupObjectPair: $json.backupObjectPair, scanMode: $json.scanMode, scanEngine: $json.scanEngine, scanRange: $json.scanRange }) }}",
        "options": {
          "allowUnauthorizedCerts": true
        }
